# Ambiente
NODE_ENV=production

# Porta do servidor
PORT=3006

# JWT Secret (gere um valor aleatório seguro)
JWT_SECRET=SEU_JWT_SECRET_AQUI

# Banco de Dados PostgreSQL
DATABASE_URL="postgresql://central_rnc_user:SUA_SENHA_AQUI@localhost:5432/central_rnc?schema=public"

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sistema@central-rnc.com.br
SMTP_PASS=SUA_SENHA_SMTP_AQUI

# URL da aplicação
APP_URL=https://central-rnc.com.br
HCAPTCHA_SECRET_KEY=SUA_HCAPTCHA_SECRET_KEY_AQUI
